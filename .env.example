# Copy this file to `.env` and paste your API key below.
# The real `.env` file is git-ignored and MUST NOT be committed.

# --- Groq (default, OpenAI-compatible) ---
OPENAI_API_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=gsk-replace-me
OPENAI_MODEL=llama-3.3-70b-versatile

# --- Google AI Studio (Gemini via OpenAI compatibility) ---
# Uncomment these to route the OpenAI SDK to Gemini instead:
# OPENAI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# OPENAI_API_KEY=replace-with-your-gemini-api-key
# OPENAI_MODEL=gemini-3-flash-preview
