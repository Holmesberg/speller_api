# Copy this file to `.env` and paste your API key below.
# The real `.env` file is git-ignored and MUST NOT be committed.

# --- Speller Model, the cheaper the better ---
SPELLER_API_BASE_URL=https://api.groq.com/openai/v1
SPELLER_API_KEY=gsk-replace-me
SPELLER_MODEL=llama-3.3-70b-versatile

# --- Response Model, the smarter the better ---
RESPONSE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
RESPONSE_API_KEY=replace-with-your-gemini-api-key
RESPONSE_MODEL=gemini-3-flash-preview